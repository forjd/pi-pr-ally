{
  "name": "pi-pr-ally",
  "version": "0.1.0",
  "description": "GitHub PR and CI copilot extension package for pi",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "extension",
    "github",
    "pull-request",
    "ci"
  ],
  "license": "MIT",
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "^0.67.68",
    "@mariozechner/pi-coding-agent": "^0.67.68",
    "@mariozechner/pi-tui": "^0.67.68",
    "@sinclair/typebox": "^0.34.49",
    "@types/node": "^24.3.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
